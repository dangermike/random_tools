#!/usr/bin/env python3

import sys
import argparse

import numpy

bin_funcs: set[str] = {"auto", "fd", "doane", "scott", "rice", "sturges", "sqrt"}

DEFAULT_HEIGHT = 1080
DEFAULT_ASPECT = (16, 9)


def parse_bins(v: str) -> "int | str":
    try:
        return int(v)
    except ValueError:
        if v not in bin_funcs:
            raise argparse.ArgumentTypeError(
                f"Cannot use {v!r} as a binning function. Available: {', '.join(sorted(bin_funcs))}"
            )
        return v


def parse_aspect(v: str) -> "tuple[int, int]":
    parts = v.split(":")
    if len(parts) != 2:
        raise argparse.ArgumentTypeError("Aspect ratio must be W:H (e.g. 16:9)")
    try:
        w, h = int(parts[0]), int(parts[1])
    except ValueError:
        raise argparse.ArgumentTypeError("Aspect ratio components must be integers")
    if w <= 0 or h <= 0:
        raise argparse.ArgumentTypeError("Aspect ratio components must be positive")
    return (w, h)


def hist(nums: list, bins, density: bool):
    h = numpy.histogram(nums, bins=bins, density=density)

    scale = 1.0
    # density is a probability density function, not a PMF; multiply by bin width
    # to normalize to 1. https://docs.scipy.org/doc/numpy-1.13.0/reference/generated/numpy.histogram.html
    if density:
        scale = h[1][1] - h[1][0]

    return h[1], h[0] * scale


def summarize(nums: list):
    pct_points = [0.0, 25.0, 50.0, 75.0, 90.0, 95.0, 99.0, 99.9, 100.0]
    percentiles = numpy.percentile(nums, pct_points)
    for b, p in zip(pct_points, percentiles):
        print("{: 6}:{: 5}".format(b, p))
    print(" count: {}".format(len(nums)))


def render_chart(edges, counts, cumulative: bool, out_file: str, width_px: int, height_px: int, xlabel: str = "Value", font_scale: float = 1.0, xlog: bool = False, ylog: bool = False):
    try:
        import matplotlib
        import matplotlib.lines
        import matplotlib.patches
        import matplotlib.ticker
        matplotlib.use("Agg")
        import matplotlib.pyplot as plt
    except ImportError:
        sys.stderr.write("matplotlib is required for chart output: pip install matplotlib\n")
        sys.exit(1)

    if font_scale != 1.0:
        for key in ("font.size", "axes.titlesize", "axes.labelsize",
                    "xtick.labelsize", "ytick.labelsize", "legend.fontsize"):
            v = matplotlib.rcParams[key]
            if isinstance(v, (int, float)):
                matplotlib.rcParams[key] = v * font_scale

    dpi = 96
    fig, ax = plt.subplots(figsize=(width_px / dpi, height_px / dpi), dpi=dpi)

    def fmt_x(v, _):
        s = f"{v:.6g}"
        if "e" in s:
            m, e = s.split("e")
            return f"{float(m):g}E{int(e)}"
        return s

    bar_widths = numpy.diff(edges)
    bar_color = "#4c72b0"
    ax.bar(edges[:-1], counts, width=bar_widths, align="edge", edgecolor="none", color=bar_color, label="Count")
    ax.xaxis.set_major_formatter(matplotlib.ticker.FuncFormatter(fmt_x))
    ax.set_xlabel(xlabel)
    ax.set_ylabel("Count (log₁₀)" if ylog else "Count")
    if xlog:
        ax.set_xscale("log")
    if ylog:
        ax.set_yscale("log")

    if cumulative:
        total = counts.sum()
        cum_pct = numpy.cumsum(counts) / total * 100.0
        # Use bin midpoints so the line sits centered over each bar
        midpoints = edges[:-1] + bar_widths / 2

        ax2 = ax.twinx()
        ax2.plot(midpoints, cum_pct, color="tab:orange", linewidth=2, marker=".", markersize=4, label="Cumulative %")
        ax2.set_ylabel("Cumulative %")
        ax2.set_ylim(0, 100)
        ax2.yaxis.set_major_formatter(matplotlib.ticker.FuncFormatter(lambda v, _: f"{v:.0f}%"))

        # Combined legend
        handles = [
            matplotlib.patches.Patch(color=bar_color, label="Count"),
            matplotlib.lines.Line2D([0], [0], color="tab:orange", linewidth=2, marker=".", markersize=6, label="Cumulative %"),
        ]
        ax.legend(handles=handles, loc="upper left")

    fig.tight_layout()
    fig.savefig(out_file)
    plt.close(fig)


def resolve_dimensions(width, height, aspect):
    ar_w, ar_h = aspect or DEFAULT_ASPECT
    ratio = ar_w / ar_h

    if width and height:
        return width, height
    if width:
        return width, round(width / ratio)
    if height:
        return round(height * ratio), height
    h = DEFAULT_HEIGHT
    return round(h * ratio), h


def main():
    parser = argparse.ArgumentParser(description="Histogram tool")
    parser.add_argument("-s", "--stats", action="store_true", help="Show summary statistics")
    parser.add_argument("-n", "--normalized", action="store_true", help="Normalize histogram (density)")
    parser.add_argument("-c", "--cumulative", action="store_true", help="Cumulative histogram")
    parser.add_argument(
        "bins", nargs="?", default="auto", type=parse_bins,
        help="Number of bins or binning function (default: auto)",
    )
    parser.add_argument("-o", "--out", metavar="FILE", help="Write chart to FILE (.png or .svg)")
    parser.add_argument("--xlabel", default="Value", metavar="LABEL", help="X-axis title (default: Value)")
    parser.add_argument("--xscale", type=float, default=1.0, metavar="FACTOR", help="Multiply bucket edges by FACTOR before display")
    parser.add_argument("--font-scale", type=float, default=2.0, metavar="FACTOR", help="Scale all font sizes by FACTOR (default: 2.0)")
    parser.add_argument("--xlog", action="store_true", help="Log10 scale on X axis")
    parser.add_argument("--ylog", action="store_true", help="Log10 scale on Y axis")
    parser.add_argument("--width", type=int, metavar="PX", help="Chart width in pixels")
    parser.add_argument("--height", type=int, metavar="PX", help="Chart height in pixels (default: 1080)")
    parser.add_argument("--aspect", type=parse_aspect, metavar="W:H", help="Aspect ratio (default: 16:9)")

    args = parser.parse_args()

    nums = []
    for line in sys.stdin:
        try:
            nums.append(float(line.strip()))
        except ValueError:
            pass

    if args.stats:
        summarize(nums)
        return

    edges, counts = hist(nums, args.bins, args.normalized)
    edges = edges * args.xscale

    if args.out:
        w, h = resolve_dimensions(args.width, args.height, args.aspect)
        render_chart(edges, counts, args.cumulative, args.out, w, h, xlabel=args.xlabel, font_scale=args.font_scale, xlog=args.xlog, ylog=args.ylog)
    else:
        if args.cumulative:
            counts = numpy.cumsum(counts)
        for x in range(len(counts)):
            print("%f\t%f" % (edges[x], counts[x]))


if __name__ == "__main__":
    main()
