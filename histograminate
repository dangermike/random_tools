#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.12"
# dependencies = ["numpy","matplotlib"]
# ///

import argparse
import sys

import numpy as np
import numpy.typing as npt

type narrayf = npt.NDArray[np.floating]

bin_funcs: set[str] = {"auto", "fd", "doane", "scott", "rice", "sturges", "sqrt"}

DEFAULT_HEIGHT = 1080
DEFAULT_ASPECT = (16, 9)


def parse_bins(v: str) -> "float | str":
    try:
        return float(v)
    except ValueError:
        if v not in bin_funcs and v != "range":
            raise argparse.ArgumentTypeError(f"Cannot use {v!r} as a binning function. Available: {', '.join(sorted(bin_funcs))}")
        return v


def parse_aspect(v: str) -> "tuple[int, int]":
    parts = v.split(":")
    if len(parts) != 2:
        raise argparse.ArgumentTypeError("Aspect ratio must be W:H (e.g. 16:9)")
    try:
        w, h = int(parts[0]), int(parts[1])
    except ValueError:
        raise argparse.ArgumentTypeError("Aspect ratio components must be integers")
    if w <= 0 or h <= 0:
        raise argparse.ArgumentTypeError("Aspect ratio components must be positive")
    return (w, h)


def hist(nums: list[float], bins: str | int | narrayf, density: bool) -> tuple[narrayf, narrayf]:
    h = np.histogram(nums, bins=bins, density=density)

    scale: float = 1.0
    # density is a probability density function, not a PMF; multiply by bin width
    # to normalize to 1. https://docs.scipy.org/doc/numpy-1.13.0/reference/generated/numpy.histogram.html
    if density:
        scale = h[1][1] - h[1][0]

    return h[1], h[0] * scale


def summarize(nums: list[float], scale: float):
    for i in range(len(nums)):
        nums[i] = nums[i] * scale
    pct_points = [0.0, 25.0, 50.0, 75.0, 90.0, 95.0, 99.0, 99.9, 100.0]
    percentiles = np.percentile(nums, pct_points)
    for b, p in zip(pct_points, percentiles):
        print("{: 6}:{: 5}".format(b, p))
    print(" count: {}".format(len(nums)))


def render_chart(
    edges: narrayf,
    counts: narrayf,
    cumulative: bool,
    out_file: str,
    width_px: int,
    height_px: int,
    xlabel: str = "Value",
    font_scale: float = 1.0,
    xlog: bool = False,
    ylog: bool = False,
):
    try:
        import matplotlib
        import matplotlib.lines
        import matplotlib.patches
        import matplotlib.ticker

        matplotlib.use("Agg")
        import matplotlib.pyplot as plt
    except ImportError:
        _ = sys.stderr.write("matplotlib is required for chart output: pip install matplotlib\n")
        sys.exit(1)

    if font_scale != 1.0:
        for key in ("font.size", "axes.titlesize", "axes.labelsize", "xtick.labelsize", "ytick.labelsize", "legend.fontsize"):
            v = matplotlib.rcParams[key]
            if isinstance(v, (int, float)):
                matplotlib.rcParams[key] = v * font_scale

    dpi = 96
    fig, ax = plt.subplots(figsize=(width_px / dpi, height_px / dpi), dpi=dpi)

    def fmt_x(v, _):
        s = f"{v:.6g}"
        if "e" in s:
            m, e = s.split("e")
            return f"{float(m):g}E{int(e)}"
        return s

    bar_widths = np.diff(edges)
    bar_color = "#4c72b0"
    ax.bar(edges[:-1], counts, width=bar_widths, align="edge", edgecolor="none", color=bar_color, label="Count")
    ax.xaxis.set_major_formatter(matplotlib.ticker.FuncFormatter(fmt_x))
    ax.set_xlabel(xlabel)
    ax.set_ylabel("Count (log₁₀)" if ylog else "Count")
    if xlog:
        ax.set_xscale("log")
    if ylog:
        ax.set_yscale("log")

    if cumulative:
        total = counts.sum()
        cum_pct = np.cumsum(counts) / total * 100.0
        # Use bin midpoints so the line sits centered over each bar
        midpoints = edges[:-1] + bar_widths / 2

        ax2 = ax.twinx()
        ax2.plot(midpoints, cum_pct, color="tab:orange", linewidth=2, marker=".", markersize=4, label="Cumulative %")
        ax2.set_ylabel("Cumulative %")
        ax2.set_ylim(0, 100)
        ax2.yaxis.set_major_formatter(matplotlib.ticker.FuncFormatter(lambda v, _: f"{v:.0f}%"))

        # Combined legend
        handles = [
            matplotlib.patches.Patch(color=bar_color, label="Count"),
            matplotlib.lines.Line2D([0], [0], color="tab:orange", linewidth=2, marker=".", markersize=6, label="Cumulative %"),
        ]
        ax.legend(handles=handles, loc="upper left")

    fig.tight_layout()
    fig.savefig(out_file)
    plt.close(fig)


def resolve_dimensions(width: int, height: int, aspect: tuple[float, float]) -> tuple[int, int]:
    ar_w, ar_h = aspect or DEFAULT_ASPECT
    ratio = ar_w / ar_h

    if width and height:
        return width, height
    if width:
        return width, int(round(width / ratio))
    if height:
        return int(round(height * ratio)), height
    h = DEFAULT_HEIGHT
    return int(round(h * ratio)), h


def resolve_bins(inbins: str | list[str | float], xscale: float) -> str | int | narrayf:
    if isinstance(inbins, str):
        return inbins
    if len(inbins) == 0:
        raise RuntimeError("no specified bins")
    if len(inbins) == 1:
        if isinstance(inbins[0], float):
            return int(inbins[0])
        else:
            return inbins[0]

    bins: narrayf
    if inbins[0] == "range":
        rparams = list(map(float, inbins[1:]))
        if len(rparams) == 1:
            bins = np.arange(0.0, rparams[0] + 1, dtype=np.float64)
        elif len(rparams) == 2:
            bins = np.arange(rparams[0], rparams[1] + 1, dtype=np.float64)
        elif len(rparams) == 3:
            bins = np.arange(rparams[0], rparams[1] + 1, rparams[2], dtype=np.float64)
        else:
            raise RuntimeError("invalid range for bins: " + ",".join(map(str, rparams)))
    else:
        bins = np.array(map(float, inbins), dtype=np.float64)
    if xscale != 1.0:
        # we need to "undo" scaling before calculating the histogram
        bins = bins / xscale

    return bins


def main():
    parser = argparse.ArgumentParser(
        prog="histograminate",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""The bins can be specified in 4 ways:
 1. Bin algorithm supported by numpy.histogram (e.g. sturges)
 2. Count of bins (e.g. 10)
 3. List of bins (e.g. 1 2 3 5 8 13)
 4. Range based on numpy.arange (e.g. range 1 10 2)
   * parameters are [start], stop, [step]

see:
 * https://numpy.org/doc/stable/reference/generated/numpy.histogram.html
 * https://numpy.org/doc/stable/reference/generated/numpy.histogram_bin_edges.html
 * https://numpy.org/doc/stable/reference/generated/numpy.arange.html""",
    )
    _ = parser.add_argument("-s", "--stats", action="store_true", help="Show summary statistics")
    _ = parser.add_argument("-n", "--normalized", action="store_true", help="Normalize histogram (density)")
    _ = parser.add_argument("-c", "--cumulative", action="store_true", help="Cumulative histogram")
    _ = parser.add_argument(
        "bins",
        nargs="*",
        default="auto",
        type=parse_bins,
        help="Number of bins or binning function (default: auto)",
    )
    _ = parser.add_argument("-o", "--out", metavar="FILE", help="Write chart to FILE (.png or .svg)")
    _ = parser.add_argument("--xlabel", default="Value", metavar="LABEL", help="X-axis title (default: Value)")
    _ = parser.add_argument("--xscale", type=float, default=1.0, metavar="FACTOR", help="Multiply bucket edges by FACTOR before display")
    _ = parser.add_argument("--font-scale", type=float, default=2.0, metavar="FACTOR", help="Chart: Scale all font sizes by FACTOR (default: 2.0)")
    _ = parser.add_argument("--xlog", action="store_true", help="Chart: Log10 scale on X axis")
    _ = parser.add_argument("--ylog", action="store_true", help="Chart: Log10 scale on Y axis")
    _ = parser.add_argument("--width", type=int, metavar="PX", help="Chart: Width in pixels")
    _ = parser.add_argument("--height", type=int, metavar="PX", help="Chart: Height in pixels (default: 1080)")
    _ = parser.add_argument("--aspect", type=parse_aspect, metavar="W:H", help="Chart: Aspect ratio (default: 16:9)")

    args = parser.parse_args()

    nums: list[float] = []
    for line in sys.stdin:
        try:
            nums.append(float(line.strip()))
        except ValueError:
            pass

    if args.stats:
        summarize(nums, args.xscale)
        return

    bins = resolve_bins(args.bins, args.xscale)
    edges, counts = hist(nums, bins, args.normalized)
    edges = edges * args.xscale

    if args.out:
        w, h = resolve_dimensions(args.width, args.height, args.aspect)
        render_chart(
            edges,
            counts,
            args.cumulative,
            args.out,
            w,
            h,
            xlabel=args.xlabel,
            font_scale=args.font_scale,
            xlog=args.xlog,
            ylog=args.ylog,
        )
    else:
        if args.cumulative:
            counts = np.cumsum(counts)
        for x in range(len(counts)):
            print("%f\t%f" % (edges[x], counts[x]))


if __name__ == "__main__":
    main()
